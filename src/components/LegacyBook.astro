---
/**
 * LegacyBook.astro — The Legacy
 * Design: O livro emerge das sombras. A citação existe antes do visitante.
 *
 * IMAGEM: Coloque a foto da capa do livro em src/assets/book-cover.jpg
 * (oriën: portrait, fundo transparente ou escuro, sem fundo branco)
 */
import { Image } from 'astro:assets';

/**
 * INSTRUCAO: Quando tiver a imagem, descomente a linha abaixo.
 *
 * import bookCoverImg from '../assets/book-cover.jpg';
 */
---

<section
  id="book-section"
  aria-label="Livro de Mario Quirino"
  class="relative w-full min-h-screen flex items-center overflow-hidden"
  style="background-color: #000000;"
>
  <div class="noise-overlay" aria-hidden="true"></div>

  <!-- Citação de fundo — parallax horizontal via GSAP scrub -->
  <div
    id="book-bg-quote"
    class="absolute inset-0 flex items-center pointer-events-none select-none overflow-hidden"
    aria-hidden="true"
    style="z-index: 0;"
  >
    <span
      class="font-serif font-bold italic whitespace-nowrap"
      style="font-size: clamp(5rem, 14vw, 18rem); color: rgba(255,255,255,0.04); letter-spacing: -0.03em; line-height: 1; will-change: transform;"
    >
      Transformação &nbsp;&nbsp; Transformação &nbsp;&nbsp; Transformação
    </span>
  </div>

  <!-- Gradiente lateral esquerdo — profundidade -->
  <div
    class="absolute left-0 top-0 bottom-0 w-1/3 pointer-events-none"
    style="background: linear-gradient(to right, #000000 0%, transparent 100%); z-index: 2;"
    aria-hidden="true"
  ></div>

  <!-- Grid principal -->
  <div class="relative z-10 w-full max-w-screen-xl mx-auto px-8 md:px-14 lg:px-20 py-28 md:py-40">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">

      <!-- Coluna Esquerda — Imagem do Livro -->
      <div class="flex justify-center lg:justify-start">
        <div
          id="book-image-wrap"
          class="relative"
          style="opacity: 0; transform: translateX(-40px);"
        >
          <!--
            =======================================================
            FOTO REAL: quando tiver book-cover.jpg em src/assets/,
            substitua o bloco div abaixo por:

            <Image
              src={bookCoverImg}
              alt="Capa do livro A Arte da Conexão Estratégica — Mario Quirino"
              class="w-full h-full object-cover"
              style="border-radius: 4px 16px 16px 4px; filter: brightness(0.9);"
              widths={[400, 700]}
              sizes="(max-width: 768px) 60vw, 28vw"
              loading="lazy"
              decoding="async"
            />
            =======================================================
          -->

          <!-- PLACEHOLDER — capa simulada. Remover quando imagem real chegar. -->
          <div
            class="relative"
            style="width: clamp(220px, 28vw, 340px); aspect-ratio: 2/3; background: linear-gradient(145deg, #1a1a1a 0%, #0d0d0d 60%, #111111 100%); border-radius: 4px 16px 16px 4px; box-shadow: 0 40px 120px rgba(0,0,0,0.9), 0 0 60px rgba(201,169,110,0.07), -8px 0 0 rgba(0,0,0,0.8), inset 4px 0 8px rgba(0,0,0,0.5);"
            aria-label="Capa do livro de Mario Quirino"
          >
            <!-- Spine -->
            <div
              class="absolute left-0 top-0 bottom-0"
              style="width: 22px; background: linear-gradient(180deg, #1f1a12 0%, rgba(201,169,110,0.15) 50%, #1f1a12 100%); border-radius: 4px 0 0 4px; border-right: 1px solid rgba(201,169,110,0.12);"
              aria-hidden="true"
            ></div>
            <div class="absolute inset-0 flex flex-col justify-between p-8 pl-12">
              <div>
                <p class="eyebrow eyebrow--accent mb-3">Mario Quirino</p>
                <p class="font-serif italic text-surface leading-tight" style="font-size: clamp(1.1rem, 2.5vw, 1.7rem);">
                  A Arte da<br />
                  <span class="text-accent">Conexão</span><br />
                  Estratégica
                </p>
              </div>
              <div style="height: 1px; background: linear-gradient(to right, rgba(201,169,110,0.4), transparent);"></div>
              <p class="font-sans font-extralight text-muted" style="font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase;">
                Como a PNL e o BNI<br />Transformam Líderes
              </p>
            </div>
            <div class="absolute inset-0 rounded-r-2xl" style="background: linear-gradient(135deg, rgba(255,255,255,0.03) 0%, transparent 50%); pointer-events: none;" aria-hidden="true"></div>
            <div class="absolute top-3 right-3 w-5 h-5 border-t border-r border-accent/20" aria-hidden="true"></div>
            <div class="absolute bottom-3 right-3 w-5 h-5 border-b border-r border-accent/20" aria-hidden="true"></div>
          </div>
          <!-- /PLACEHOLDER -->

          <!-- Sombra projetada -->
          <div class="absolute bottom-0 left-8 right-8" style="height: 40px; background: rgba(0,0,0,0.8); filter: blur(20px); transform: translateY(20px) scaleY(0.3); border-radius: 50%;" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Coluna Direita — Conteúdo -->
      <div id="book-content" style="opacity: 0; transform: translateX(30px);">

        <p class="eyebrow eyebrow--accent mb-6">O Legado em Papel</p>

        <h2 class="font-serif font-bold text-surface leading-none tracking-tighter mb-8" style="font-size: clamp(2.5rem, 5vw, 5.5rem);">
          Cada página,<br />uma <span class="text-accent italic">decisão</span>.
        </h2>

        <div class="gold-rule mb-8"></div>

        <p class="font-sans font-extralight text-muted leading-relaxed mb-6" style="font-size: clamp(0.95rem, 1.4vw, 1.05rem); max-width: 42ch;">
          Décadas de experiência em PNL e liderança condensadas em um guia prático
          para quem entende que crescer é uma escolha deliberada — não uma consequência do acaso.
        </p>

        <p class="font-sans font-extralight text-muted leading-relaxed mb-12" style="font-size: clamp(0.95rem, 1.4vw, 1.05rem); max-width: 42ch;">
          Um livro que não fala sobre sucesso. Fala sobre o que vem antes dele.
        </p>

        <div class="flex flex-col items-start gap-4">
          <a href="#book-purchase" class="btn-ghost-white" aria-label="Adquirir o livro de Mario Quirino">
            <span>Adquirir o Livro &nbsp;→</span>
          </a>
          <p class="font-sans font-extralight text-muted" style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;">
            Enviado para todo o Brasil &nbsp;·&nbsp; Exemplar com dedicatória disponível
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- Gradiente de transição inferior -->
  <div class="absolute bottom-0 left-0 right-0 h-40 pointer-events-none" style="background: linear-gradient(to bottom, transparent, #000000); z-index: 3;" aria-hidden="true"></div>
</section>

<style>
  .btn-ghost-white {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: #FFFFFF;
    padding: 1rem 2.5rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.75rem;
    font-weight: 400;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: color 0.5s ease, border-color 0.5s ease, letter-spacing 0.4s ease;
    text-decoration: none;
  }
  .btn-ghost-white::before {
    content: '';
    position: absolute;
    inset: 0;
    background: #FFFFFF;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.5s cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 0;
  }
  .btn-ghost-white span { position: relative; z-index: 1; }
  .btn-ghost-white:hover { color: #000000; border-color: #FFFFFF; letter-spacing: 0.25em; }
  .btn-ghost-white:hover::before { transform: scaleX(1); }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const pref = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (pref) {
    gsap.set(['#book-image-wrap', '#book-content'], { opacity: 1, x: 0 });
  } else {
    // Citação de fundo — parallax horizontal lento
    gsap.fromTo('#book-bg-quote span',
      { x: '5%' },
      {
        x: '-15%',
        ease: 'none',
        scrollTrigger: {
          trigger: '#book-section',
          start: 'top bottom',
          end: 'bottom top',
          scrub: 2,
        },
      }
    );

    // Reveal do livro — emerge da sombra, vindo da esquerda
    gsap.to('#book-image-wrap', {
      opacity: 1,
      x: 0,
      duration: 1.4,
      ease: 'power4.out',
      scrollTrigger: { trigger: '#book-section', start: 'top 72%', once: true },
    });

    // Parallax vertical do livro
    gsap.to('#book-image-wrap', {
      y: -30,
      ease: 'none',
      scrollTrigger: {
        trigger: '#book-section',
        start: 'top bottom',
        end: 'bottom top',
        scrub: 1.5,
      },
    });

    // Reveal do conteúdo textual
    gsap.to('#book-content', {
      opacity: 1,
      x: 0,
      duration: 1.2,
      ease: 'power3.out',
      delay: 0.15,
      scrollTrigger: { trigger: '#book-section', start: 'top 72%', once: true },
    });
  }
</script>
