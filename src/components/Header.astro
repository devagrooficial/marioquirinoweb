---
/**
 * Header.astro — O Olho que Observa Tudo
 * Mario Quirino Landing Page
 *
 * Design: Header invisível com mix-blend-difference.
 * A logo inverte de cor automaticamente ao passar por fundos claros.
 */
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
---

<header
  id="site-header"
  role="banner"
  aria-label="Cabeçalho do site de Mario Quirino"
  class="fixed top-0 left-0 w-full z-50"
  style="
    padding: 1.5rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    /* Gradiente preto descendente — protege a logo e o menu
       sem bloquear o conteúdo da página. Dissolve em ~8rem. */
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,0.85) 0%,
      rgba(0,0,0,0.5)  50%,
      transparent      100%
    );
    height: 8rem;
  "
>

  <!-- ── LOGO ────────────────────────────────────────────────── -->
  <!-- mix-blend-difference aplicado individualmente:
       a logo inverte sobre fundos claros, mas o gradiente
       preto do header a isola no topo. -->
  <div class="mix-blend-difference" style="align-self: flex-start; padding-top: 0.25rem;">
    <a
      href="/"
      id="header-logo"
      aria-label="Ir para o início — Mario Quirino"
      style="display: block; line-height: 0; text-decoration: none;"
    >
      <Image
        src={logoImg}
        alt="Logo Mario Quirino"
        class="h-[50px] w-auto rounded-[10px]"
        loading="eager"
        decoding="async"
      />
    </a>
  </div>

  <!-- ── BOTÃO DE MENU ───────────────────────────────────────────── -->
  <!-- mix-blend-difference isolado no menu também -->
  <div class="mix-blend-difference" style="align-self: flex-start; padding-top: 0.5rem;">
    <button
      id="header-menu-btn"
      type="button"
      aria-label="Abrir menu de navegação"
      aria-expanded="false"
      aria-controls="mobile-nav"
      style="
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
        color: #ffffff;
      "
    >
      <!-- Label "MENU" -->
      <span
        style="
          font-family: 'Inter', sans-serif;
          font-size: 0.6rem;
          font-weight: 400;
          letter-spacing: 0.3em;
          text-transform: uppercase;
          color: #ffffff;
          line-height: 1;
        "
      >
        MENU
      </span>

      <!-- Ícone de hambúrguer — duas linhas ultrafinas -->
      <div
        id="header-hamburger"
        style="display: flex; flex-direction: column; gap: 5px; width: 24px;"
        aria-hidden="true"
      >
        <span
          id="ham-line-1"
          style="display: block; width: 100%; height: 1px; background: #ffffff; transform-origin: right center; transition: transform 0.4s cubic-bezier(0.76, 0, 0.24, 1), opacity 0.3s ease;"
        ></span>
        <span
          id="ham-line-2"
          style="display: block; width: 70%; height: 1px; background: #ffffff; margin-left: auto; transform-origin: right center; transition: transform 0.4s cubic-bezier(0.76, 0, 0.24, 1), width 0.4s ease;"
        ></span>
      </div>
    </button>
  </div>

</header>

<!--
  ── MENU OVERLAY (estrutura preparada, fechado por padrão) ──
  A lógica de abrir/fechar fica no <script> abaixo.
  O overlay usa position: fixed e cobre toda a tela com
  um fundo preto. O mix-blend-difference NÃO se aplica aqui
  (precisamos de fundo real para o menu funcionar).
-->
<nav
  id="mobile-nav"
  role="navigation"
  aria-label="Menu principal"
  aria-hidden="true"
  style="
    position: fixed;
    inset: 0;
    z-index: 49;
    background: #000000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding: 2rem;
    padding-left: clamp(2rem, 8vw, 8rem);
    transform: translateY(-100%);
    will-change: transform;
    transition: transform 0.7s cubic-bezier(0.76, 0, 0.24, 1);
  "
>
  <!-- Noise overlay no menu -->
  <div
    class="noise-overlay"
    style="position: absolute; inset: 0; pointer-events: none;"
    aria-hidden="true"
  ></div>

  <!-- Links de navegação -->
  <ul role="list" style="list-style: none; padding: 0; margin: 0; position: relative; z-index: 1;">
    {[
      { label: 'Início',       href: '#hero'          },
      { label: 'Sobre',        href: '#about-section' },
      { label: 'Aplicativo',   href: '#app-section'   },
      { label: 'Livro',        href: '#book-section'  },
      { label: 'Evento',       href: '#event-section' },
    ].map((link, i) => (
      <li style={`--i: ${i};`}>
        <a
          href={link.href}
          class="nav-link"
          style="
            font-family: 'Playfair Display', serif;
            font-size: clamp(2.5rem, 6vw, 5rem);
            font-weight: 700;
            color: rgba(255,255,255,0.15);
            text-decoration: none;
            line-height: 1.1;
            letter-spacing: -0.02em;
            display: block;
            transition: color 0.3s ease;
          "
          onmouseover="this.style.color='#ffffff'"
          onmouseout="this.style.color='rgba(255,255,255,0.15)'"
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>

  <!-- Rodapé do menu -->
  <div
    style="
      position: absolute;
      bottom: 2.5rem;
      left: clamp(2rem, 8vw, 8rem);
      right: 2rem;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      z-index: 1;
    "
  >
    <p
      style="
        font-family: 'Inter', sans-serif;
        font-size: 0.6rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.2);
      "
    >
      © 2025 Mario Quirino
    </p>
    <div style="height: 1px; width: 80px; background: rgba(201,169,110,0.3);"></div>
  </div>
</nav>

<style>
  /* Hover nos links de nav — cursor de luxo */
  .nav-link:hover {
    color: #ffffff !important;
  }
  /* Remove outline padrão, usa focus-visible para acessibilidade */
  #header-menu-btn:focus-visible {
    outline: 1px solid rgba(201, 169, 110, 0.6);
    outline-offset: 4px;
    border-radius: 2px;
  }
</style>

<script>
  const btn = document.getElementById('header-menu-btn') as HTMLButtonElement;
  const nav = document.getElementById('mobile-nav') as HTMLElement;
  const line1 = document.getElementById('ham-line-1') as HTMLElement;
  const line2 = document.getElementById('ham-line-2') as HTMLElement;

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    nav.style.transform = 'translateY(0)';
    nav.setAttribute('aria-hidden', 'false');
    btn.setAttribute('aria-expanded', 'true');
    // Anima as linhas para X
    line1.style.transform = 'rotate(-45deg) translateY(3px)';
    line2.style.transform = 'rotate(45deg) translateY(-3px)';
    line2.style.width = '100%';
    line2.style.marginLeft = '0';
    // Bloqueia o scroll do Lenis durante o menu
    if ((window as any).__lenis) (window as any).__lenis.stop();
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isOpen = false;
    nav.style.transform = 'translateY(-100%)';
    nav.setAttribute('aria-hidden', 'true');
    btn.setAttribute('aria-expanded', 'false');
    // Volta para hambúrguer
    line1.style.transform = 'none';
    line2.style.transform = 'none';
    line2.style.width = '70%';
    line2.style.marginLeft = 'auto';
    // Reativa o Lenis
    if ((window as any).__lenis) (window as any).__lenis.start();
    document.body.style.overflow = '';
  }

  btn.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu();
  });

  // Fechar ao clicar em qualquer link do menu
  nav.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Fechar com Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) closeMenu();
  });
</script>
