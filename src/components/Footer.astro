---
/**
 * Footer.astro — Closing Frame
 * Minimalismo absoluto. O silêncio depois da música.
 */

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/marioquirino', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
  { label: 'LinkedIn',  href: 'https://linkedin.com/in/marioquirino',  icon: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { label: 'YouTube',   href: 'https://youtube.com/@marioquirino',     icon: 'M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z' },
];

const year = new Date().getFullYear();
---

<footer
  id="footer"
  role="contentinfo"
  aria-label="Rodapé do site de Mario Quirino"
  class="relative w-full overflow-hidden"
  style="background-color: #000000;"
>

  <!-- Linha separadora superior — gold fantasma -->
  <div
    class="w-full"
    style="height: 1px; background: linear-gradient(90deg, transparent, rgba(201,169,110,0.15) 20%, rgba(201,169,110,0.15) 80%, transparent);"
    aria-hidden="true"
  ></div>

  <div class="max-w-screen-xl mx-auto px-8 md:px-14 lg:px-20 py-16 md:py-20">

    <!-- Grid do footer: Nome + Links -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10">

      <!-- Nome — Assinatura tipográfica -->
      <div>
        <p
          class="font-serif font-bold text-surface tracking-tighter leading-none"
          style="font-size: clamp(1.5rem, 3vw, 2.5rem); color: rgba(255,255,255,0.85);"
        >
          MARIO QUIRINO
        </p>
        <p class="eyebrow text-muted mt-2" style="letter-spacing: 0.25em;">
          Especialista Nacional em PNL &nbsp;·&nbsp; BNI
        </p>
      </div>

      <!-- Links Sociais -->
      <nav aria-label="Redes sociais de Mario Quirino">
        <ul class="flex items-center gap-6" role="list">
          {socialLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visitar ${link.label} de Mario Quirino`}
                class="footer-social-link"
              >
                <svg
                  width="18" height="18"
                  viewBox="0 0 24 24"
                  fill="currentColor"
                  aria-hidden="true"
                >
                  <path d={link.icon} />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>

    <!-- Linha divisória fina -->
    <div
      class="my-10"
      style="height: 1px; background: rgba(255,255,255,0.05);"
      aria-hidden="true"
    ></div>

    <!-- Rodapé inferior — copyright + selos centralizados -->
    <div class="flex flex-col items-center gap-4 text-center">

      <!-- Copyright -->
      <p
        class="font-sans font-extralight text-muted"
        style="font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase;"
      >
        &copy; {year} Mario Quirino. Todos os direitos reservados.
      </p>

      <!-- Selos de tecnologia e legal — centralizados -->
      <div class="flex flex-wrap justify-center items-center gap-x-8 gap-y-4 w-full">

        <!-- MQ Access badge minimalista -->
        <div class="mq-access-badge" aria-label="Tecnologia MQ Access exclusiva">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="rgba(201,169,110,0.6)" aria-hidden="true">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
          </svg>
          <span>MQ Access™</span>
        </div>

        <!-- Links legais -->
        <a
          href="/privacidade"
          class="font-sans font-extralight text-muted hover:text-surface transition-colors duration-300"
          style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;"
        >
          Privacidade
        </a>
        <a
          href="/termos"
          class="font-sans font-extralight text-muted hover:text-surface transition-colors duration-300"
          style="font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;"
        >
          Termos
        </a>
      </div>
    </div>

  </div>
</footer>

<style>
  .footer-social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.3);
    transition: color 0.35s ease, transform 0.35s ease;
  }
  .footer-social-link:hover {
    color: #C9A96E;
    transform: translateY(-2px);
  }
</style>
