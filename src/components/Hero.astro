---
/**
 * Hero.astro — The Opening Frame
 * Mario Quirino Landing Page
 */
import { Image } from 'astro:assets';
import heroImg from '../assets/hero-mario.jpeg';
---

<section
  id="hero"
  aria-label="Apresentação de Mario Quirino"
  class="relative w-full min-h-screen overflow-hidden bg-void flex items-center"
>
  <!-- Noise overlay — grão cinematográfico -->
  <div class="noise-overlay" aria-hidden="true"></div>

  <!-- Linha divisória vertical -->
  <div
    id="hero-divider"
    aria-hidden="true"
    class="absolute top-0 bottom-0 left-1/2 w-px opacity-0"
    style="background: linear-gradient(180deg, transparent 0%, rgba(201,169,110,0.2) 30%, rgba(201,169,110,0.2) 70%, transparent 100%);"
  ></div>

  <!-- Layout: texto à esquerda (relativo), foto cobre a direita em absolute -->
  <div class="relative z-10 w-full min-h-screen">

    <!-- Coluna Esquerda — Conteúdo Textual -->
    <!-- Ocupa 50% da tela no desktop; z-20 garante legibilidade sobre a foto -->
    <div
      class="relative z-20 w-full lg:w-1/2 flex flex-col justify-end"
      style="min-height: 100vh; padding: 0 2.5rem 5rem 5rem;"
    >

      <!-- Eyebrow Label -->
      <div id="hero-eyebrow" class="eyebrow eyebrow--accent mb-6 opacity-0">
        Diretor Executivo BNI &nbsp;·&nbsp; Especialista Nacional em PNL
      </div>

      <!-- Título Principal — 2 linhas com máscara de reveal por linha -->
      <h1
        id="hero-title"
        class="font-serif font-bold text-surface tracking-tighter"
        style="font-size: clamp(3.5rem, 6vw, 8.5rem); line-height: 0.9; letter-spacing: -0.03em;"
      >
        <!-- Linha 1: MARIO — branco -->
        <span class="block overflow-hidden">
          <span
            id="hero-line-1"
            class="block"
            style="transform: translateY(110%); color: #ffffff;"
          >MARIO</span>
        </span>
        <!-- Linha 2: QUIRINO — gold -->
        <span class="block overflow-hidden">
          <span
            id="hero-line-2"
            class="block"
            style="transform: translateY(110%); color: #C9A96E;"
          >QUIRINO</span>
        </span>
      </h1>

      <!-- Subtítulo -->
      <div class="overflow-hidden mt-6">
        <p
          id="hero-subtitle"
          class="font-sans font-extralight text-muted text-xl md:text-2xl tracking-wide"
          style="transform: translateY(100%); opacity: 0;"
        >
          A Maestria da Mente.<br />
          O Poder da Conexão.
        </p>
      </div>

      <!-- CTA -->
      <div id="hero-cta" class="mt-12 flex flex-col sm:flex-row items-start gap-6 opacity-0">
        <div class="gold-rule self-center hidden sm:block"></div>
        <a
          href="#contact"
          class="btn-ghost"
          aria-label="Iniciar conversa com Mario Quirino"
        >
          <span>Iniciar Conversa &nbsp;→</span>
        </a>
      </div>

      <!-- Scroll hint -->
      <div id="hero-scroll-hint" class="mt-16 lg:mt-20 flex items-center gap-3 opacity-0" aria-hidden="true">
        <div class="w-px h-10" style="background: linear-gradient(to bottom, transparent, rgba(201,169,110,0.4));"></div>
        <span class="eyebrow">Role para descobrir</span>
      </div>
    </div>

    <!-- Foto — cobre toda a metade direita + sangra até a borda -->
    <!-- position: absolute; right: 0; width: 58%; height: 100vh -->
    <div
      class="hidden lg:block absolute top-0 right-0 h-screen z-10"
      style="width: 58%;"
    >
      <div
        id="hero-photo-frame"
        class="relative w-full h-full overflow-hidden"
        style="transform: scale(1.04); opacity: 0; transform-origin: right center;"
      >
        <!-- Foto real — object-right para mostrar o rosto e o pin BNI -->
        <Image
          src={heroImg}
          alt="Mario Quirino — Especialista Nacional em PNL e Diretor Executivo BNI"
          class="w-full h-full object-cover"
          style="object-position: center top; filter: grayscale(100%) brightness(0.75) contrast(1.25);"
          widths={[800, 1200, 1600]}
          sizes="60vw"
          loading="eager"
          decoding="async"
        />

        <!-- Gradiente esquerdo — protege legibilidade do texto sobre a foto -->
        <div
          class="absolute inset-y-0 left-0 pointer-events-none"
          style="width: 55%; background: linear-gradient(to right, #000000 0%, rgba(0,0,0,0.4) 60%, transparent 100%); z-index: 2;"
          aria-hidden="true"
        ></div>

        <!-- Gradiente inferior — transição para próxima seção -->
        <div
          class="absolute inset-x-0 bottom-0 pointer-events-none"
          style="height: 45%; background: linear-gradient(to top, #000000 0%, transparent 100%); z-index: 2;"
          aria-hidden="true"
        ></div>

        <!-- Gradiente superior — integra com o header -->
        <div
          class="absolute inset-x-0 top-0 pointer-events-none"
          style="height: 18%; background: linear-gradient(to bottom, #000000 0%, transparent 100%); z-index: 2;"
          aria-hidden="true"
        ></div>
      </div>
    </div>

  </div>

  <!-- Gradiente de transição para próxima seção -->
  <div
    class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none"
    style="background: linear-gradient(to bottom, transparent, #000000);"
    aria-hidden="true"
  ></div>
</section>

<script>
  import { gsap } from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (prefersReducedMotion) {
      gsap.set(
        ['#hero-eyebrow', '#hero-title', '#hero-subtitle', '#hero-cta', '#hero-scroll-hint', '#hero-divider', '#hero-photo-frame'],
        { opacity: 1, y: 0, scale: 1 }
      );
      return;
    }

    const tl = gsap.timeline({ defaults: { ease: 'power4.out', duration: 1.5 } });

    // 1. Linha divisória
    tl.to('#hero-divider', { opacity: 1, duration: 1.2, ease: 'power2.out' }, 0.2);

    // 2. Eyebrow
    tl.to('#hero-eyebrow', { opacity: 1, y: 0, duration: 1.0, ease: 'power3.out' }, 0.4);

    // 3. Título em 2 linhas — stagger em cascata (0.14s entre cada linha)
    tl.to('#hero-line-1', { y: 0, duration: 1.6, ease: 'power4.out' }, 0.5);
    tl.to('#hero-line-2', { y: 0, duration: 1.6, ease: 'power4.out' }, 0.64);

    // 4. Subtítulo
    tl.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1.2, ease: 'power3.out' }, 1.0);

    // 5. CTA
    tl.to('#hero-cta', { opacity: 1, y: 0, duration: 1.0, ease: 'power2.out' }, 1.3);

    // 6. Scroll hint
    tl.to('#hero-scroll-hint', { opacity: 1, duration: 0.8, ease: 'power2.out' }, 1.7);

    // 7. Frame fotográfico — escala de 1.06 → 1, entra com o título
    tl.to('#hero-photo-frame', { opacity: 1, scale: 1, duration: 1.8, ease: 'power3.out' }, 0.3);
  });
</script>
